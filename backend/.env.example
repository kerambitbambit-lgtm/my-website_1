# Конфигурация базы данных
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=my_website_db

# JWT секретный ключ (замените на свой в production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Порт сервера
PORT=3001

# URL фронтенда (для CORS)
FRONTEND_URL=http://localhost:3000
